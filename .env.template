# Copy this file to .env and fill in your values

# ==============================================================================
# LLM Configuration (cloud vs local)
# ==============================================================================

# Use local LLM instead of cloud API (Ollama / vLLM / Hugging Face)
# Set to 1, true, or yes to enable. Can also use --local-llm CLI flag.
USE_LOCAL_LLM=0

# Cloud API (OpenAI-compatible)
OPENAI_API_KEY=your_openai_api_key_here

# Cloud models (OpenAI)
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ==============================================================================
# Local LLM Configuration (Ollama / vLLM / Hugging Face Inference)
# ==============================================================================

# Base URL for local OpenAI-compatible API
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Chat model name (e.g., llama3.2, mistral, Qwen2-7B-Instruct)
LOCAL_LLM_MODEL=glm-4.7-flash

# Embedding model name (e.g., nomic-embed-text for Ollama)
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# API key for local LLM (usually empty or "ollama" for Ollama)
LOCAL_LLM_API_KEY=

# ==============================================================================
# Couchbase Configuration
# ==============================================================================

CB_CONNECTION_STRING=couchbase://localhost
CB_USERNAME=Administrator
CB_PASSWORD=password
CB_BUCKET=default
CB_COLLECTION=_default
CB_SEARCH_INDEX=proposal_talks_index
